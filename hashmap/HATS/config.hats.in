#ifndef HASHMAP_HATS_CONFIG_HATS_HEADER_GUARD__ #then
#define HASHMAP_HATS_CONFIG_HATS_HEADER_GUARD__

#define BIGENDIAN @BIGENDIAN@
#define LITTLEENDIAN @LITTLEENDIAN@
#define UNIVERSALENDIAN @UNIVERSALENDIAN@
#define ENDIANNESS @ENDIANNESS@

#define SIZEOF_USINT @SIZEOF_USINT@
#define SIZEOF_UINT @SIZEOF_UINT@
#define SIZEOF_ULINT @SIZEOF_ULINT@
#define SIZEOF_ULLINT @SIZEOF_ULLINT@
#define SIZEOF_SIZE @SIZEOF_SIZE@
#define SIZEOF_SIZE_T @SIZEOF_SIZE@
#define SIZEOF_UINTPTR @SIZEOF_UINTPTR@
#define SIZEOF_UINT8 @SIZEOF_UINT8@
#define SIZEOF_UINT16 @SIZEOF_UINT16@
#define SIZEOF_UINT32 @SIZEOF_UINT32@
#define SIZEOF_UINT64 @SIZEOF_UINT64@

(* Eight times the respective SIZEOF_typename. *)
#define BITSIZEOF_USINT @BITSIZEOF_USINT@
#define BITSIZEOF_UINT @BITSIZEOF_UINT@
#define BITSIZEOF_ULINT @BITSIZEOF_ULINT@
#define BITSIZEOF_ULLINT @BITSIZEOF_ULLINT@
#define BITSIZEOF_SIZE @BITSIZEOF_SIZE@
#define BITSIZEOF_SIZE_T @BITSIZEOF_SIZE@
#define BITSIZEOF_UINTPTR @BITSIZEOF_UINTPTR@
#define BITSIZEOF_UINT8 @BITSIZEOF_UINT8@
#define BITSIZEOF_UINT16 @BITSIZEOF_UINT16@
#define BITSIZEOF_UINT32 @BITSIZEOF_UINT32@
#define BITSIZEOF_UINT64 @BITSIZEOF_UINT64@

(* For declaring arrays when converting to strings, or
   for similar uses. *)
#define BITSIZEOF_USINT_PLUS_ONE @BITSIZEOF_USINT_PLUS_ONE@
#define BITSIZEOF_UINT_PLUS_ONE @BITSIZEOF_UINT_PLUS_ONE@
#define BITSIZEOF_ULINT_PLUS_ONE @BITSIZEOF_ULINT_PLUS_ONE@
#define BITSIZEOF_ULLINT_PLUS_ONE @BITSIZEOF_ULLINT_PLUS_ONE@
#define BITSIZEOF_SIZE_PLUS_ONE @BITSIZEOF_SIZE_PLUS_ONE@
#define BITSIZEOF_SIZE_T_PLUS_ONE @BITSIZEOF_SIZE_PLUS_ONE@
#define BITSIZEOF_UINTPTR_PLUS_ONE @BITSIZEOF_UINTPTR_PLUS_ONE@
#define BITSIZEOF_UINT8_PLUS_ONE @BITSIZEOF_UINT8_PLUS_ONE@
#define BITSIZEOF_UINT16_PLUS_ONE @BITSIZEOF_UINT16_PLUS_ONE@
#define BITSIZEOF_UINT32_PLUS_ONE @BITSIZEOF_UINT32_PLUS_ONE@
#define BITSIZEOF_UINT64_PLUS_ONE @BITSIZEOF_UINT64_PLUS_ONE@

(* How many bits to extract from a hash value (or numeric key)
   at a time. *)
#define SIZEOF_BITINDEXOF_UINTPTR @SIZEOF_BITINDEXOF_UINTPTR@

#endif (* HASHMAP_HATS_CONFIG_HATS_HEADER_GUARD__ *)
