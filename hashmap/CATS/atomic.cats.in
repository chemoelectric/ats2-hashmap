#ifndef HEADER_GUARD_@ATS_EXTERN_PREFIX@ATOMIC_CATS__
#define HEADER_GUARD_@ATS_EXTERN_PREFIX@ATOMIC_CATS__

#include <stdatomic.h>

/********************************************************************/

typedef atomic_int @ATS_EXTERN_PREFIX@atomic_int;
typedef volatile atomic_int *@ATS_EXTERN_PREFIX@atomic_int_ptr;

typedef atomic_size_t @ATS_EXTERN_PREFIX@atomic_size_t;
typedef volatile atomic_size_t *@ATS_EXTERN_PREFIX@atomic_size_t_ptr;

ATSinline() @ATS_EXTERN_PREFIX@atomic_int_ptr
@ATS_EXTERN_PREFIX@atomic_int_ref2ptr (atstype_ref p)
{
  return (@ATS_EXTERN_PREFIX@atomic_int_ptr) (void *) p;
}

#define @ATS_EXTERN_PREFIX@atomic_thread_fence_seq_cst() \
  atomic_thread_fence (memory_order_seq_cst)

#define @ATS_EXTERN_PREFIX@atomic_load_seq_cst(p) \
  atomic_load_explicit ((p), memory_order_seq_cst)

#define @ATS_EXTERN_PREFIX@atomic_load_acquire(p) \
  atomic_load_explicit ((p), memory_order_acquire)

#define @ATS_EXTERN_PREFIX@atomic_store_release(p, value) \
  atomic_store_explicit((p), (value), memory_order_release)

#define @ATS_EXTERN_PREFIX@atomic_fetch_add_seq_cst(p, n) \
  atomic_fetch_add_explicit ((p), (n), memory_order_seq_cst)

#define @ATS_EXTERN_PREFIX@atomic_fetch_sub_seq_cst(p, n) \
  atomic_fetch_sub_explicit ((p), (n), memory_order_seq_cst)

/********************************************************************/

#endif /* HEADER_GUARD_@ATS_EXTERN_PREFIX@ATOMIC_CATS__ */
