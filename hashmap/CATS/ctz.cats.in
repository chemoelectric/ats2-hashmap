#ifndef HEADER_GUARD_@ATS_EXTERN_PREFIX@CTZ_CATS__
#define HEADER_GUARD_@ATS_EXTERN_PREFIX@CTZ_CATS__

#define @ATS_EXTERN_PREFIX@ctz_cats_inline ATSinline()

#define @ATS_EXTERN_PREFIX@KNOWN_TO_HAVE_CTZ_BUILTINS  \
  (4 <= __GNUC__) ||                                        \
  (3 <= __GNUC__ && 4 <= __GNUC_MINOR__) ||                 \
  (4 <= __clang_major__)

#ifndef HAVE___BUILTIN_CTZ
#if @ATS_EXTERN_PREFIX@KNOWN_TO_HAVE_CTZ_BUILTINS
#define HAVE___BUILTIN_CTZ 1
#endif
#endif

#ifndef HAVE___BUILTIN_CTZL
#if @ATS_EXTERN_PREFIX@KNOWN_TO_HAVE_CTZ_BUILTINS
#define HAVE___BUILTIN_CTZL 1
#endif
#endif

#ifndef HAVE___BUILTIN_CTZLL
#if @ATS_EXTERN_PREFIX@KNOWN_TO_HAVE_CTZ_BUILTINS
#define HAVE___BUILTIN_CTZLL 1
#endif
#endif

#if HAVE___BUILTIN_CTZ
@ATS_EXTERN_PREFIX@ctz_cats_inline atstype_int
@ATS_EXTERN_PREFIX@builtin_ctz_uint (atstype_uint x)
{
  return __builtin_ctz (x);
}
#endif

#if HAVE___BUILTIN_CTZL
@ATS_EXTERN_PREFIX@ctz_cats_inline atstype_int
@ATS_EXTERN_PREFIX@builtin_ctz_ulint (atstype_ulint x)
{
  return __builtin_ctzl (x);
}
#endif

#if HAVE___BUILTIN_CTZLL
@ATS_EXTERN_PREFIX@ctz_cats_inline atstype_int
@ATS_EXTERN_PREFIX@builtin_ctz_ullint (atstype_ullint x)
{
  return __builtin_ctzll (x);
}
#endif

@ATS_EXTERN_PREFIX@ctz_cats_inline atstype_int
@ATS_EXTERN_PREFIX@fallback_ctz_uint32 (atstype_uint32 x)
{
  /* See https://web.archive.org/web/20160801030139/http://7ooo.mooo.com/text/ComputingTrailingZerosHOWTO.pdf */
  static const atstype_int8 table[32] =
    { 0, 1, 28, 2, 29, 14, 24, 3, 30, 22, 20, 15, 25, 17, 4, 8,
      31, 27, 13, 23, 21, 19, 16, 7, 26, 12, 18, 6, 11, 5, 10, 9 };
  /* The "& 0x1F" guarantees against buffer overrun. */
  return table[(((x & (-x)) * UINT32_C (0x077CB531)) >> 27) & 0x1F];
}

@ATS_EXTERN_PREFIX@ctz_cats_inline atstype_int
@ATS_EXTERN_PREFIX@fallback_ctz_uint64 (atstype_uint64 x)
{
  /* See https://www.chessprogramming.org/index.php?title=BitScan&oldid=22495
     This is the "separated LS1B" algorithm. */
  static const atstype_int8 table[64] =
    { 0, 47, 1, 56, 48, 27, 2, 60,
      57, 49, 41, 37, 28, 16, 3, 61,
      54, 58, 35, 52, 50, 42, 21, 44,
      38, 32, 29, 23, 17, 11, 4, 62,
      46, 55, 26, 59, 40, 36, 15, 53,
      34, 51, 20, 43, 31, 22, 10, 45,
      25, 39, 14, 33, 19, 30, 9, 24,
      13, 18, 8, 12, 7, 6, 5, 63 };
  /* The "& 0x3F" guarantees against buffer overrun. */
  return table[(((x ^ (x - 1)) * UINT64_C (0x03F79D71B4CB0A89)) >> 58) & 0x3F];
}

#define @ATS_EXTERN_PREFIX@g0uint_ctz_uint32 @ATS_EXTERN_PREFIX@fallback_ctz_uint32
#if SIZEOF_UINT32_T <= SIZEOF_UNSIGNED_INT && HAVE___BUILTIN_CTZ
#  undef @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint32 @ATS_EXTERN_PREFIX@builtin_ctz_uint
#elif SIZEOF_UINT32_T <= SIZEOF_UNSIGNED_LONG_INT && HAVE___BUILTIN_CTZL
#  undef @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint32 @ATS_EXTERN_PREFIX@builtin_ctz_ulint
#elif SIZEOF_UINT32_T <= SIZEOF_UNSIGNED_LONG_LONG_INT && HAVE___BUILTIN_CTZLL
#  undef @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint32 @ATS_EXTERN_PREFIX@builtin_ctz_ullint
#endif

#define @ATS_EXTERN_PREFIX@g0uint_ctz_uint64 @ATS_EXTERN_PREFIX@fallback_ctz_uint64
#if SIZEOF_UINT64_T <= SIZEOF_UNSIGNED_INT && HAVE___BUILTIN_CTZ
#  undef @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint64 @ATS_EXTERN_PREFIX@builtin_ctz_uint
#elif SIZEOF_UINT64_T <= SIZEOF_UNSIGNED_LONG_INT && HAVE___BUILTIN_CTZL
#  undef @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint64 @ATS_EXTERN_PREFIX@builtin_ctz_ulint
#elif SIZEOF_UINT64_T <= SIZEOF_UNSIGNED_LONG_LONG_INT && HAVE___BUILTIN_CTZLL
#  undef @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint64 @ATS_EXTERN_PREFIX@builtin_ctz_ullint
#endif

#if HAVE___BUILTIN_CTZ
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint @ATS_EXTERN_PREFIX@builtin_ctz_uint
#elif SIZEOF_UNSIGNED_INT <= SIZEOF_UINT32_T
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#elif SIZEOF_UNSIGNED_INT <= SIZEOF_UINT64_T
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uint @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
#else
   /* FIXME: This can be implemented with a loop. */
#  error "I have no implementation for g0uint_ctz_uint; consider using GCC."
#endif

#if HAVE___BUILTIN_CTZL
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_ulint @ATS_EXTERN_PREFIX@builtin_ctz_ulint
#elif SIZEOF_UNSIGNED_LONG_INT <= SIZEOF_UINT32_T
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_ulint @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#elif SIZEOF_UNSIGNED_LONG_INT <= SIZEOF_UINT64_T
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_ulint @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
#else
   /* FIXME: This can be implemented with a loop. */
#  error "I have no implementation for g0uint_ctz_ulint; consider using GCC."
#endif

#if HAVE___BUILTIN_CTZLL
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_ullint @ATS_EXTERN_PREFIX@builtin_ctz_ullint
#elif SIZEOF_UNSIGNED_LONG_LONG_INT <= SIZEOF_UINT32_T
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_ullint @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#elif SIZEOF_UNSIGNED_LONG_LONG_INT <= SIZEOF_UINT64_T
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_ullint @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
#else
   /* FIXME: This can be implemented with a loop. */
#  error "I have no implementation for g0uint_ctz_ullint; consider using GCC."
#endif

#if SIZEOF_SIZE_T <= SIZEOF_UNSIGNED_INT
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_size @ATS_EXTERN_PREFIX@g0uint_ctz_uint
#elif SIZEOF_SIZE_T <= SIZEOF_UNSIGNED_LONG_INT
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_size @ATS_EXTERN_PREFIX@g0uint_ctz_ulint
#elif SIZEOF_SIZE_T <= SIZEOF_UNSIGNED_LONG_LONG_INT
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_size @ATS_EXTERN_PREFIX@g0uint_ctz_ullint
#else
   /* FIXME: This can be implemented with a loop. */
#  error "I have no ctz implementation for size_t."
#endif

#if SIZEOF_UINTPTR_T <= SIZEOF_UNSIGNED_INT
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uintptr @ATS_EXTERN_PREFIX@g0uint_ctz_uint
#elif SIZEOF_UINTPTR_T <= SIZEOF_UNSIGNED_LONG_INT
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uintptr @ATS_EXTERN_PREFIX@g0uint_ctz_ulint
#elif SIZEOF_UINTPTR_T <= SIZEOF_UNSIGNED_LONG_LONG_INT
#  define @ATS_EXTERN_PREFIX@g0uint_ctz_uintptr @ATS_EXTERN_PREFIX@g0uint_ctz_ullint
#else
   /* FIXME: This can be implemented with a loop. */
#  error "I have no ctz implementation for uintptr_t."
#endif

#define @ATS_EXTERN_PREFIX@g0uint_ctz_usint @ATS_EXTERN_PREFIX@g0uint_ctz_uint
#define @ATS_EXTERN_PREFIX@g0uint_ctz_uint8 @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#define @ATS_EXTERN_PREFIX@g0uint_ctz_uint16 @ATS_EXTERN_PREFIX@g0uint_ctz_uint32

#define @ATS_EXTERN_PREFIX@g1uint_ctz_usint @ATS_EXTERN_PREFIX@g0uint_ctz_usint
#define @ATS_EXTERN_PREFIX@g1uint_ctz_uint @ATS_EXTERN_PREFIX@g0uint_ctz_uint
#define @ATS_EXTERN_PREFIX@g1uint_ctz_ulint @ATS_EXTERN_PREFIX@g0uint_ctz_ulint
#define @ATS_EXTERN_PREFIX@g1uint_ctz_ullint @ATS_EXTERN_PREFIX@g0uint_ctz_ullint
#define @ATS_EXTERN_PREFIX@g1uint_ctz_uint8 @ATS_EXTERN_PREFIX@g0uint_ctz_uint8
#define @ATS_EXTERN_PREFIX@g1uint_ctz_uint16 @ATS_EXTERN_PREFIX@g0uint_ctz_uint16
#define @ATS_EXTERN_PREFIX@g1uint_ctz_uint32 @ATS_EXTERN_PREFIX@g0uint_ctz_uint32
#define @ATS_EXTERN_PREFIX@g1uint_ctz_uint64 @ATS_EXTERN_PREFIX@g0uint_ctz_uint64
