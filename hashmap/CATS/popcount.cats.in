#ifndef HEADER_GUARD_@ATS_EXTERN_PREFIX@POPCOUNT_CATS__
#define HEADER_GUARD_@ATS_EXTERN_PREFIX@POPCOUNT_CATS__

/********************************************************************/
/*
 * Population count.
 */

#include <stdint.h>
#include <stdbit.h>

#define @ATS_EXTERN_PREFIX@g0uint_popcount_uint32(x) \
        stdc_count_ones ((uint32_t) (x))

#define @ATS_EXTERN_PREFIX@g0uint_popcount_uint64(x) \
        stdc_count_ones ((uint64_t) (x))

#define @ATS_EXTERN_PREFIX@g1uint_popcount_uint32(x) \
        stdc_count_ones ((uint32_t) (x))

#define @ATS_EXTERN_PREFIX@g1uint_popcount_uint64(x) \
        stdc_count_ones ((uint64_t) (x))

#define @ATS_EXTERN_PREFIX@g0uint_popcount_low_bits_uint32(x, i) \
  stdc_count_ones (((uint32_t) (x)) & ~((~(uint32_t) 0)<<(i)))

#define @ATS_EXTERN_PREFIX@g0uint_popcount_low_bits_uint64(x, i) \
  stdc_count_ones (((uint64_t) (x)) & ~((~(uint64_t) 0)<<(i)))

#define @ATS_EXTERN_PREFIX@g1uint_popcount_low_bits_uint32(x, i) \
  stdc_count_ones (((uint32_t) (x)) & ~((~(uint32_t) 0)<<(i)))

#define @ATS_EXTERN_PREFIX@g1uint_popcount_low_bits_uint64(x, i) \
  stdc_count_ones (((uint64_t) (x)) & ~((~(uint64_t) 0)<<(i)))

/********************************************************************/

#endif /* HEADER_GUARD_@ATS_EXTERN_PREFIX@POPCOUNT_CATS__ */
