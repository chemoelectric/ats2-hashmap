#ifndef HEADER_GUARD_@ATS_EXTERN_PREFIX@CONST_CATS__
#define HEADER_GUARD_@ATS_EXTERN_PREFIX@CONST_CATS__

#ifndef ats2_hashmap_attribute_const
#  if (defined __GNUC__) && (10 <= __GNUC__)
     /* This is the new proposed standard notation for attributes.
        Let us use it. */
#    define @ATS_EXTERN_PREFIX@attribute_const [[gnu::const]]
#  elif (defined __GNUC__) && (3 <= __GNUC__)
#    define @ATS_EXTERN_PREFIX@attribute_const __attribute__((__const__))
#  elif (defined __GNUC__) && (2 <= __GNUC__) && (5 <= __GNUC_MINOR__)
#    define @ATS_EXTERN_PREFIX@attribute_const __attribute__((__const__))
#  elif (defined __clang__) /* I do not know what versions support. */
#    define @ATS_EXTERN_PREFIX@attribute_const __attribute__((__const__))
#  else
#    define @ATS_EXTERN_PREFIX@attribute_const /* nothing */
#  endif
#endif

#endif /* HEADER_GUARD_@ATS_EXTERN_PREFIX@CONST_CATS__ */
