#undef ATS_PACKNAME
#define ATS_PACKNAME "@ATS_PACKNAME@"

#undef ATS_EXTERN_PREFIX
#define ATS_EXTERN_PREFIX "@ATS_EXTERN_PREFIX@"

%{#
#include "@ATS_CATS_DIRECTORY@/memory.cats"
%}

(********************************************************************)
(*
  Copying or setting memory.
*)

(* An interface to memcpy or __builtin_memcpy. *)
fun
memcpy {n   : int}
       (dst : &(@[byte?][n]) >> @[byte][n],
        src : &RD(@[byte][n]),
        n   : size_t n) :<!refwrt> void = "mac#%"

(* An interface to memset or __builtin_memset. *)
fun
memset {n     : int}
       (dst   : &(@[byte?][n]) >> @[byte][n],
        value : byte,
        n     : size_t n) :<!refwrt> void = "mac#%"

(* Move the elements of one array to another array.
   This is equivalent to the prelude's "array_copy"
   template; for a nonlinear type, it is a copy. For
   a linear type, it is a "move" that leaves the old
   array filled with the equivalent nonlinear data. *)
fun {vt : vt@ype}
array_move1 {length : int}
            (dst    : &(@[vt?][length]) >> @[vt][length],
             src    : &RD(@[INV(vt)][length]) >> @[vt?!][length],
             length : size_t length) :<!refwrt> void
overload array_move with array_move1

(* Move the elements of one array to another array. *)
fun {vt : vt@ype}
array_move2 {length : int}
            {p_dst  : addr}
            {p_src  : addr}
            (pf_dst : !(@[vt?][length] @ p_dst) >>
                          @[vt][length] @ p_dst,
             pf_src : !(@[INV(vt)][length] @ p_src) >>
                          @[vt?!][length] @ p_src |
             p_dst  : ptr p_dst,
             p_src  : ptr p_src,
             length : size_t length) :<!refwrt> void
overload array_move with array_move2

(* Copy "length" elements from one initialized nonlinear
   array into another. *)
fun {t : t@ype}
array_copy_elements
        {n1, n2 : int}
        {i1, i2 : int}
        {length : int | i1 + length <= n1; i2 + length <= n2}
        (dst    : &(@[t][n1]),
         i1     : size_t i1,
         src    : &RD(@[INV(t)][n2]),
         i2     : size_t i2,
         length : size_t length) :<!refwrt> void

(********************************************************************)
(*
  Swapping byte order.
*)

fun {tk : tkind}
g0uint_bswap : g0uint (tk) -<> g0uint (tk)

fun g0uint_bswap_usint : usint -<> usint = "mac#%"
fun g0uint_bswap_uint : uint -<> uint = "mac#%"
fun g0uint_bswap_ulint : ulint -<> ulint = "mac#%"
fun g0uint_bswap_ullint : ullint -<> ullint = "mac#%"
fun g0uint_bswap_uint8 : uint8 -<> uint8 = "mac#%"
fun g0uint_bswap_uint16 : uint16 -<> uint16 = "mac#%"
fun g0uint_bswap_uint32 : uint32 -<> uint32 = "mac#%"
fun g0uint_bswap_uint64 : uint64 -<> uint64 = "mac#%"
fun g0uint_bswap_size : size_t -<> size_t = "mac#%"
fun g0uint_bswap_uintptr : uintptr -<> uintptr = "mac#%"

overload bswap with g0uint_bswap of 0

(********************************************************************)
(*
  Setting byte order to little-endian.
*)

fun {tk : tkind}
g0uint_little_endian : g0uint (tk) -<> g0uint (tk)

fun g0uint_little_endian_usint : usint -<> usint = "mac#%"
fun g0uint_little_endian_uint : uint -<> uint = "mac#%"
fun g0uint_little_endian_ulint : ulint -<> ulint = "mac#%"
fun g0uint_little_endian_ullint : ullint -<> ullint = "mac#%"
fun g0uint_little_endian_uint8 : uint8 -<> uint8 = "mac#%"
fun g0uint_little_endian_uint16 : uint16 -<> uint16 = "mac#%"
fun g0uint_little_endian_uint32 : uint32 -<> uint32 = "mac#%"
fun g0uint_little_endian_uint64 : uint64 -<> uint64 = "mac#%"
fun g0uint_little_endian_size : size_t -<> size_t = "mac#%"
fun g0uint_little_endian_uintptr : uintptr -<> uintptr = "mac#%"

overload little_endian with g0uint_little_endian of 0

(********************************************************************)
