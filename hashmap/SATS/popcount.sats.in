#undef ATS_PACKNAME
#define ATS_PACKNAME "@ATS_PACKNAME@"

#undef ATS_EXTERN_PREFIX
#define ATS_EXTERN_PREFIX "@ATS_EXTERN_PREFIX@"

%{#
#include "@ATS_CATS_DIRECTORY@/popcount.cats"
%}

#ifndef ATS2_POPCOUNT_CHAR_BIT #then
#define ATS2_POPCOUNT_CHAR_BIT 8
#endif

(********************************************************************)

(* "popcount" is the number of 1-bits set in x. *)
absprop POPCOUNT (x : int, popcount : int)
stacst popcount_relation (x : int, popcount : int) : bool

(* "popcount" is the number of 1-bits set in x,
   ignoring all bits of index i or higher. *)
absprop POPCOUNT_LOW_BITS (x : int, i : int, popcount : int)
stacst popcount_low_bits_relation (x : int, i : int,
                                   popcount : int) : bool

praxi
popcount_relation_to_proof :
  {x        : int}
  {popcount : int | popcount_relation (x, popcount)}
  () -<prf> POPCOUNT (x, popcount)

praxi
proof_to_popcount_relation :
  {x        : int}
  {popcount : int}
  POPCOUNT (x, popcount) -<prf>
    [popcount_relation (x, popcount)] void

praxi
popcount_low_bits_relation_to_proof :
  {x        : int}
  {i        : int}
  {popcount : int | popcount_low_bits_relation (x, i, popcount)}
  () -<prf> POPCOUNT_LOW_BITS (x, i, popcount)

praxi
proof_to_popcount_low_bits_relation :
  {x        : int}
  {i        : int}
  {popcount : int}
  POPCOUNT_LOW_BITS (x, i, popcount) -<prf>
    [popcount_low_bits_relation (x, i, popcount)] void

praxi
popcount_isfun :
  {x : int}
  {popcount1, popcount2 : int}
  (POPCOUNT (x, popcount1),
   POPCOUNT (x, popcount2)) -<prf>
    [popcount1 == popcount2] void

prfun
lemma_popcount_isfun :
  {x : int}
  {popcount1, popcount2 : int | popcount_relation (x, popcount1);
                                popcount_relation (x, popcount2)}
  () -<prf> [popcount1 == popcount2] void

praxi
popcount_low_bits_isfun :
  {x : int}
  {i : int}
  {popcount1, popcount2 : int}
  (POPCOUNT_LOW_BITS (x, i, popcount1),
   POPCOUNT_LOW_BITS (x, i, popcount2)) -<prf>
    [popcount1 == popcount2] void

prfun
lemma_popcount_low_bits_isfun :
  {x : int}
  {i : int}
  {popcount1, popcount2 : int |
      popcount_low_bits_relation (x, i, popcount1);
      popcount_low_bits_relation (x, i, popcount2)}
   () -<prf> [popcount1 == popcount2] void

praxi
popcount_is_nonnegative :
  {x : int}
  {popcount : int}
  POPCOUNT (x, popcount) -<prf>
    [0 <= popcount] void

prfun
lemma_popcount_is_nonnegative :
  {x : int}
  {popcount : int | popcount_relation (x, popcount)}
  () -<prf> [0 <= popcount] void

praxi {tk : tkind}
popcount_param :
  {x : int}
  {popcount : int}
  (POPCOUNT (x, popcount) | g1uint (tk, x)) -<prf>
    [0 <= popcount;
     popcount <= ATS2_POPCOUNT_CHAR_BIT * sizeof (g1uint (tk, x))]
    void

prfun {tk : tkind}
lemma_popcount_param :
  {x : int}
  {popcount : int | popcount_relation (x, popcount)}
  g1uint (tk, x) -<prf>
    [0 <= popcount;
     popcount <= ATS2_POPCOUNT_CHAR_BIT * sizeof (g1uint (tk, x))]
    void

praxi
popcount_low_bits_is_nonnegative :
  {x : int}
  {i : int}
  {popcount : int}
  POPCOUNT_LOW_BITS (x, i, popcount) -<prf>
    [0 <= popcount] void

praxi
lemma_popcount_low_bits_is_nonnegative :
  {x : int}
  {i : int}
  {popcount : int | popcount_low_bits_relation (x, i, popcount)}
  () -<prf> [0 <= popcount] void

praxi
popcount_low_bits_bound :
  {x : int}
  {i : int}
  {popcount : int}
  POPCOUNT_LOW_BITS (x, i, popcount) -<prf>
    [popcount <= i] void

praxi
lemma_popcount_low_bits_bound :
  {x : int}
  {i : int}
  {popcount : int | popcount_low_bits_relation (x, i, popcount)}
  () -<prf> [popcount <= i] void

praxi
popcount_fewer_bits_1 :
  {x : int}
  {i : int}
  {popcount1, popcount2 : int}
  (POPCOUNT (x, popcount1),
   POPCOUNT_LOW_BITS (x, i, popcount2)) -<prf>
    [popcount2 <= popcount1] void

prfun
lemma_popcount_fewer_bits_1 :
  {x : int}
  {i : int}
  {popcount1, popcount2 : int |
        popcount_relation (x, popcount1);
        popcount_low_bits_relation (x, i, popcount2)}
  () -<prf> [popcount2 <= popcount1] void

praxi
popcount_fewer_bits_2 :
  {x : int}
  {i1, i2 : int | i2 <= i1}
  {popcount1, popcount2 : int}
  (POPCOUNT_LOW_BITS (x, i1, popcount1),
   POPCOUNT_LOW_BITS (x, i2, popcount2)) -<prf>
    [popcount2 <= popcount1] void

prfun
lemma_popcount_fewer_bits_2 :
  {x : int}
  {i1, i2 : int | i2 <= i1}
  {popcount1, popcount2 : int |
        popcount_low_bits_relation (x, i1, popcount1);
        popcount_low_bits_relation (x, i2, popcount2)}
  () -<prf> [popcount2 <= popcount1] void


(********************************************************************)
(*
  Population count.
*)

(* An interface to stdc_count_ones(3). *)

fun {tk : tkind}
g0uint_popcount : g0uint (tk) -<> int

fun
g0uint_popcount_uint32 :
  uint32 -<> int = "mac#%"
fun
g0uint_popcount_uint64 :
  uint64 -<> int = "mac#%"

fun {tk : tkind}
g1uint_popcount :
  {x : int}
  g1uint (tk, x) -<>
    [popcount : int | popcount_relation (x, popcount)]
    int popcount

fun {tk : tkind}
g1uint_popcount_with_proof :
  {x : int}
  g1uint (tk, x) -<>
    [popcount : int]
    @(POPCOUNT (x, popcount) | int popcount)

fun
g1uint_popcount_uint32 :
  {x : int}
  uint32 x -<>
    [popcount : int | popcount_relation (x, popcount)]
    int popcount = "mac#%"

fun
g1uint_popcount_uint64 :
  {x : int}
  uint64 x -<>
    [popcount : int | popcount_relation (x, popcount)]
    int popcount = "mac#%"

(********************************************************************)
(* Compute and return the number of 1-bits set in x,
   ignoring all bits of index i or higher. *)

fun {tk : tkind}
g0uint_popcount_low_bits : (g0uint (tk), uint) -<> int

fun
g0uint_popcount_low_bits_uint32 :
  (uint32, uint) -<> int = "mac#%"
fun
g0uint_popcount_low_bits_uint64 :
  (uint64, uint) -<> int = "mac#%"

fun {tk : tkind}
g1uint_popcount_low_bits :
  {x : int}
  {i : int | i < ATS2_POPCOUNT_CHAR_BIT * sizeof (g1uint (tk, x))}
  (g1uint (tk, x), uint i) -<>
    [popcount : int | popcount_low_bits_relation (x, i, popcount)]
    int popcount

fun {tk : tkind}
g1uint_popcount_low_bits_with_proof :
  {x : int}
  {i : int | i < ATS2_POPCOUNT_CHAR_BIT * sizeof (g1uint (tk, x))}
  (g1uint (tk, x), uint i) -<>
    [popcount : int]
    @(POPCOUNT_LOW_BITS (x, i, popcount) | int popcount)

fun
g1uint_popcount_low_bits_uint32 :
  {x : int}
  {i : int | i < ATS2_POPCOUNT_CHAR_BIT * sizeof (uint32)}
  (uint32 x, uint i) -<>
    [popcount : int | popcount_low_bits_relation (x, i, popcount)]
    int popcount = "mac#%"

fun
g1uint_popcount_low_bits_uint64 :
  {x : int}
  {i : int | i < ATS2_POPCOUNT_CHAR_BIT * sizeof (uint64)}
  (uint64 x, uint i) -<>
    [popcount : int | popcount_low_bits_relation (x, i, popcount)]
    int popcount = "mac#%"

(********************************************************************)

overload popcount with g0uint_popcount of 0
overload popcount with g1uint_popcount of 20
overload popcount_with_proof with g1uint_popcount_with_proof of 0

overload popcount_low_bits with g0uint_popcount_low_bits of 0
overload popcount_low_bits with g1uint_popcount_low_bits of 20
overload popcount_low_bits_with_proof with
  g1uint_popcount_low_bits_with_proof of 0

(********************************************************************)
