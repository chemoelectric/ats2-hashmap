#ifndef HEADER_GUARD_@ATS_EXTERN_PREFIX@CATS_SPINLOCK_CATS__
#define HEADER_GUARD_@ATS_EXTERN_PREFIX@CATS_SPINLOCK_CATS__

#include <stdatomic.h>
#include "@ATS_CATS_DIRECTORY@/atomic.cats"

/********************************************************************/

#ifdef __GNUC__

/*
 * FIXME: Similar things can be done for other platforms and other
 *        compilers.
 */
#if defined(__i386__) || defined(__x86_64__)
#define @ATS_EXTERN_PREFIX@pause() __builtin_ia32_pause ()
#endif

#else

#define @ATS_EXTERN_PREFIX@pause() do { /* nothing */ } while (0)

#endif

/********************************************************************/

typedef struct
{
  /* Use unsigned integers, so they will wrap around when they
     overflow. */
  @ATS_EXTERN_PREFIX@atomic_size_t active;
  @ATS_EXTERN_PREFIX@atomic_size_t available;
} @ATS_EXTERN_PREFIX@spinlock_struct_t;

typedef @ATS_EXTERN_PREFIX@spinlock_struct_t *@ATS_EXTERN_PREFIX@spinlock_t;

ATSinline() @ATS_EXTERN_PREFIX@spinlock_t
@ATS_EXTERN_PREFIX@spinlock_alloc (void)
{
  @ATS_EXTERN_PREFIX@spinlock_t lock =
    ATS_MALLOC (sizeof (@ATS_EXTERN_PREFIX@spinlock_struct_t));
  lock->active = 0;
  lock->available = 0;
  return lock;
}

ATSinline() void
@ATS_EXTERN_PREFIX@spinlock_free (@ATS_EXTERN_PREFIX@spinlock_t lock)
{
  ATS_MFREE (lock);
}

ATSinline() @ATS_EXTERN_PREFIX@spinlock_struct_t
@ATS_EXTERN_PREFIX@spinlock_data (void)
{
  @ATS_EXTERN_PREFIX@spinlock_struct_t lock;
  lock.active = 0;
  lock.available = 0;
  return lock;
}

ATSinline() @ATS_EXTERN_PREFIX@atomic_size_t_ptr
@ATS_EXTERN_PREFIX@spinlock_active_p (@ATS_EXTERN_PREFIX@spinlock_t lock)
{
  return &(lock->active);
}

ATSinline() @ATS_EXTERN_PREFIX@atomic_size_t_ptr
@ATS_EXTERN_PREFIX@spinlock_available_p (@ATS_EXTERN_PREFIX@spinlock_t lock)
{
  return &(lock->available);
}

/********************************************************************/

#endif /* HEADER_GUARD_@ATS_EXTERN_PREFIX@CATS_SPINLOCK_CATS__ */
