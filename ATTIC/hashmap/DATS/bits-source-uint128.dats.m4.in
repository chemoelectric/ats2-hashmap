#define ATS_PACKNAME "ats2-hashmap"
#define ATS_DYNLOADFLAG 0

#if @HAVE_UINT128@ #then

include(`common-macros.m4')
m4_define(`UINTTYPE',`uint128')
m4_define(`BITSIZEU', `128U')

staload BITS_SOURCE = "hashmap/SATS/bits-source.sats"

typedef uint128 = $BITS_SOURCE.hashmap_uint128
typedef uint128 (u : int) = $extype"unsigned __int128"

extern castfn
g1ofg0_uint128 :
  uint128 -<> [u : int | 0 <= u] uint128 u

overload g1ofg0 with g1ofg0_uint128 of 10000

m4_include(`hashmap/DATS/bits-source-UINTTYPE.dats.m4')

#else (* not HAVE_UINT128 *)

#define ATS_PACKNAME "ats2-hashmap"
#define ATS_EXTERN_PREFIX "ats2_hashmap_"

#define ATS_DYNLOADFLAG 0

#include "share/atspre_staload.hats"

staload "hashmap/SATS/bits-source.sats"

implement
make_bits_source_uint128 (num_bits) =
  begin
    assertlocmsg
      (false,
       ": hashmap_uint128 is not supported by this installation");
    $UNSAFE.castvwtp0 (the_null_ptr)
  end

#endif (* not HAVE_UINT128 *)
