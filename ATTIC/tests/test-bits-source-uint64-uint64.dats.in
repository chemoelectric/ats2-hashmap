fn
test_one_time () : void =
  {
    fn
    source_func {num_bits    : int}
                (bits_source : bits_source_cloref (@(uint64, uint64),
                                                   num_bits),
                 hash        : @(uint64, uint64),
                 depth       : uint) :
        [bits : int]
        (BITS_SOURCE_BITS (num_bits, bits) | int bits) =
      let
        var h = hash
      in
        bits_source (h, depth)
      end

    macdef source (hash, depth) =
      source_func (bits_source_uint64_uint64 (), ,(hash), ,(depth))

    (* FIXME: Currently testing is done only if sizeof(uintptr) = 8,
              as for instance on AMD64. *)
    val _ =
      if sizeof<uintptr> = i2sz 8 then
        {
          val hash = @(cast64 0xBA5EBA11FACEF00DU,
                       cast64 0xDEADBEEF12345678U)

          #ifdef HAVE_UINT128 #then
            val _ =
              let
                val hash_as_uint128 =
                  add_uint128 (cast128 hash.0,
                               mul_uint128 (two_raised_64, cast128 hash.1))
                var i : [i : nat] uint i
                var u : uint128 = cast128 0
                var factor : uint128 = cast128 1
              in
                for (i := 0U; i < 41U; i := succ i)
                  let
                    val bits = cast128 (source (hash, i)).1
                  in
                    u := add_uint128 (u, mul_uint128 (bits, factor));
                    factor := mul_uint128 (factor, cast128 64U)
                  end;
                assertloc (eq_uint128 (u, hash_as_uint128))
              end
          #endif

          val _ = assertloc ((source (hash, 0U)).1 = 0x0D)
          val _ = assertloc ((source (hash, 1U)).1 = 0x00)
          val _ = assertloc ((source (hash, 2U)).1 = 0x2F)
