#define ATS_PACKNAME "ats2-hashmap"
#define ATS_EXTERN_PREFIX "ats2_hashmap_"

#define ATS_DYNLOADFLAG 0

#include "share/atspre_define.hats"
#include "share/atspre_staload.hats"

staload "hashmap/SATS/bits-source.sats"

%{^
#undef my_add
#define my_add(u, v) ((u) + (v))

#undef my_mul
#define my_mul(u, v) ((u) * (v))

#undef my_eq
#define my_eq(u, v) ((u) == (v))
%}

#if @HAVE_UINT128@ #then
  #define HAVE_UINT128 1
#else
  #undef HAVE_UINT128
#endif

#ifdef HAVE_UINT128 #then
  typedef uint128 = $extype"unsigned __int128"

  extern fn
  add_uint128 (u : uint128,
               v : uint128) :<> uint128 = "mac#my_add"

  extern fn
  mul_uint128 (u : uint128,
               v : uint128) :<> uint128 = "mac#my_mul"

  extern fn
  eq_uint128 (u : uint128,
              v : uint128) :<> bool = "mac#my_eq"

#endif

macdef cast64 = $UNSAFE.cast{uint64}

#ifdef HAVE_UINT128 #then
  macdef cast128 = $UNSAFE.cast{uint128}
  macdef two_raised_32 = cast128 4294967296
  macdef two_raised_64 = mul_uint128 (two_raised_32, two_raised_32)
#endif

fn
test_num_bits_eq_4 () : void =
  {
    val hash = @(cast64 0xBA5EBA11FACEF00DU,
                 cast64 0xDEADBEEF12345678U)
    val bits_source = make_bits_source_uint64_uint64 (4U)

    fn
    source_func (bits_source : !bits_source_cloptr
                                  (@(uint64, uint64), 4) >> _,
                 hash        : @(uint64, uint64),
                 depth       : uint) :
        [bits : int]
        (BITS_SOURCE_BITS (4, bits) | int bits) =
      let
        var h = hash
      in
        bits_source (h, depth)
      end
    macdef source (hash, depth) =
      source_func (bits_source, ,(hash), ,(depth))

    #ifdef HAVE_UINT128 #then
      val _ =
        let
          val hash_as_uint128 =
            add_uint128 (cast128 hash.0,
                         mul_uint128 (two_raised_64, cast128 hash.1))
          var i : [i : nat] uint i
          var u : uint128 = cast128 0
          var factor : uint128 = cast128 1
        in
          for (i := 0U; i < 41U; i := succ i)
            let
              val bits = cast128 (source (hash, i)).1
            in
              u := add_uint128 (u, mul_uint128 (bits, factor));
              factor := mul_uint128 (factor, cast128 16U)
            end;
          assertloc (eq_uint128 (u, hash_as_uint128))
        end
    #endif

    val _ = assertloc ((source (hash, 0U)).1 = 0xD)
    val _ = assertloc ((source (hash, 1U)).1 = 0x0)
    val _ = assertloc ((source (hash, 2U)).1 = 0x0)
    val _ = assertloc ((source (hash, 3U)).1 = 0xF)
    val _ = assertloc ((source (hash, 4U)).1 = 0xE)
    val _ = assertloc ((source (hash, 5U)).1 = 0xC)
    val _ = assertloc ((source (hash, 6U)).1 = 0xA)
    val _ = assertloc ((source (hash, 7U)).1 = 0xF)
    val _ = assertloc ((source (hash, 8U)).1 = 0x1)
    val _ = assertloc ((source (hash, 9U)).1 = 0x1)
    val _ = assertloc ((source (hash, 10U)).1 = 0xA)
    val _ = assertloc ((source (hash, 11U)).1 = 0xB)
    val _ = assertloc ((source (hash, 12U)).1 = 0xE)
    val _ = assertloc ((source (hash, 13U)).1 = 0x5)
    val _ = assertloc ((source (hash, 14U)).1 = 0xA)
    val _ = assertloc ((source (hash, 15U)).1 = 0xB)
    val _ = assertloc ((source (hash, 16U)).1 = 0x8)
    val _ = assertloc ((source (hash, 17U)).1 = 0x7)
    val _ = assertloc ((source (hash, 18U)).1 = 0x6)
    val _ = assertloc ((source (hash, 19U)).1 = 0x5)
    val _ = assertloc ((source (hash, 20U)).1 = 0x4)
    val _ = assertloc ((source (hash, 21U)).1 = 0x3)
    val _ = assertloc ((source (hash, 22U)).1 = 0x2)
    val _ = assertloc ((source (hash, 23U)).1 = 0x1)
    val _ = assertloc ((source (hash, 24U)).1 = 0xF)
    val _ = assertloc ((source (hash, 25U)).1 = 0xE)
    val _ = assertloc ((source (hash, 26U)).1 = 0xE)
    val _ = assertloc ((source (hash, 27U)).1 = 0xB)
    val _ = assertloc ((source (hash, 28U)).1 = 0xD)
    val _ = assertloc ((source (hash, 29U)).1 = 0xA)
    val _ = assertloc ((source (hash, 30U)).1 = 0xE)
    val _ = assertloc ((source (hash, 31U)).1 = 0xD)
    val _ = assertloc ((source (hash, 32U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 33U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 34U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 35U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 36U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 37U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 38U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 39U)).1 = BITS_SOURCE_EXHAUSTED)
    val _ = assertloc ((source (hash, 100U)).1 = BITS_SOURCE_EXHAUSTED)

    val _ = free (bits_source)
  }

fn
test_num_bits_eq_5 () : void =
  {
